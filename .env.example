# Скопируй в .env и заполни своими ключами:  cp .env.example .env

# --- Голова (генеративный LLM) ---
# Groq free API, OpenAI-совместимый. Модель: gpt-oss-120b. Бесплатный ключ:
#   https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Голова (Router-результат -> RAG/Agent): gpt-oss-120b
LLM_MODEL=openai/gpt-oss-120b
# Router (быстрая классификация болтовня/поиск/детали): llama-3.1-8b-instant
ROUTER_MODEL=llama-3.1-8b-instant

# --- Telegram-бот (bot.py) ---
# Токен от @BotFather: напиши ему /newbot и вставь сюда выданный токен.
TELEGRAM_BOT_TOKEN=

# --- LangSmith (трассировка запросов агента, опционально) ---
# Бесплатный ключ: https://smith.langchain.com -> Settings -> API Keys.
# Включи трассировку и вставь ключ — трейсы появятся в проекте на дашборде.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=find-my-movie

# --- Веб-поиск (инструмент web_search) ---
# Бесплатный ключ: https://app.tavily.com
TAVILY_API_KEY=

# --- Эмбеддер ---
# Локальный fastembed multilingual-e5-large — КЛЮЧ НЕ НУЖЕН (офлайн, бесплатно).
EMBED_MODEL=intfloat/multilingual-e5-large
